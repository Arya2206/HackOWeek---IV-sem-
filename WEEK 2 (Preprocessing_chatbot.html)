<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Week 2 — Text Preprocessing Chatbot</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet"/>
<style>
  :root {
    --bg: #0d0f14;
    --surface: #151820;
    --surface2: #1c2030;
    --border: #2a2f42;
    --accent: #38bdf8;
    --accent2: #06b6d4;
    --user-bubble: #0c2d40;
    --bot-bubble: #1a1f2e;
    --text: #e8eaf0;
    --text-muted: #7880a0;
    --green: #4ade80;
    --yellow: #fbbf24;
    --font-head: 'Syne', sans-serif;
    --font-mono: 'DM Mono', monospace;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-mono);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }
  .wrapper {
    width: 100%;
    max-width: 760px;
    display: flex;
    flex-direction: column;
    height: 92vh;
    gap: 0;
  }
  /* Header */
  .header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 1.2rem 1.5rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-bottom: none;
    border-radius: 16px 16px 0 0;
  }
  .bot-avatar {
    width: 42px; height: 42px;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.2rem;
    flex-shrink: 0;
  }
  .header-info h1 { font-family: var(--font-head); font-size: 1rem; font-weight: 700; }
  .header-info p { font-size: 0.7rem; color: var(--text-muted); margin-top: 2px; }
  .status-dot {
    width: 8px; height: 8px;
    background: var(--green);
    border-radius: 50%;
    display: inline-block;
    margin-right: 5px;
    animation: pulse 2s infinite;
  }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
  .week-tag {
    margin-left: auto;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 4px 10px;
    font-size: 0.65rem;
    color: var(--accent);
    letter-spacing: 0.05em;
  }
  /* Main layout — chat + debug panel */
  .main {
    flex: 1;
    display: flex;
    overflow: hidden;
    border: 1px solid var(--border);
    border-top: none;
    border-bottom: none;
  }
  .chat-area {
    flex: 1;
    background: var(--surface);
    padding: 1.5rem;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    scroll-behavior: smooth;
  }
  .chat-area::-webkit-scrollbar { width: 4px; }
  .chat-area::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }
  /* Debug panel */
  .debug-panel {
    width: 240px;
    background: #0a0c12;
    border-left: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    flex-shrink: 0;
  }
  .debug-header {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border);
    font-size: 0.65rem;
    color: var(--accent);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .debug-dot {
    width: 6px; height: 6px;
    background: var(--yellow);
    border-radius: 50%;
    animation: pulse 1s infinite;
  }
  .debug-content {
    flex: 1;
    overflow-y: auto;
    padding: 0.75rem;
    font-size: 0.68rem;
    color: var(--text-muted);
    line-height: 1.7;
  }
  .debug-content::-webkit-scrollbar { width: 3px; }
  .debug-content::-webkit-scrollbar-thumb { background: var(--border); }
  .debug-section {
    margin-bottom: 0.9rem;
    animation: fadeIn 0.3s ease;
  }
  @keyframes fadeIn { from{opacity:0} to{opacity:1} }
  .debug-label {
    font-size: 0.6rem;
    color: var(--yellow);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 3px;
  }
  .debug-value {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 5px 8px;
    word-break: break-all;
    color: var(--green);
  }
  .debug-token {
    display: inline-block;
    background: rgba(56,189,248,0.1);
    border: 1px solid rgba(56,189,248,0.2);
    color: var(--accent);
    border-radius: 4px;
    padding: 1px 5px;
    margin: 2px;
    font-size: 0.62rem;
  }
  .debug-removed {
    display: inline-block;
    background: rgba(251,191,36,0.08);
    border: 1px solid rgba(251,191,36,0.15);
    color: var(--yellow);
    border-radius: 4px;
    padding: 1px 5px;
    margin: 2px;
    font-size: 0.62rem;
    text-decoration: line-through;
    opacity: 0.7;
  }
  .debug-empty { color: var(--text-muted); font-style: italic; font-size: 0.65rem; }
  /* Messages */
  .msg-row { display: flex; gap: 10px; animation: fadeUp 0.25s ease; }
  @keyframes fadeUp { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }
  .msg-row.user { flex-direction: row-reverse; }
  .msg-avatar {
    width: 32px; height: 32px;
    border-radius: 9px;
    flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.85rem;
    margin-top: 2px;
  }
  .msg-row.bot .msg-avatar { background: linear-gradient(135deg, var(--accent), var(--accent2)); }
  .msg-row.user .msg-avatar { background: var(--user-bubble); border: 1px solid var(--accent); }
  .bubble {
    max-width: 80%;
    padding: 0.7rem 1rem;
    border-radius: 12px;
    font-size: 0.82rem;
    line-height: 1.6;
  }
  .msg-row.bot .bubble { background: var(--bot-bubble); border: 1px solid var(--border); border-top-left-radius: 4px; }
  .msg-row.user .bubble { background: var(--user-bubble); border: 1px solid rgba(56,189,248,0.25); border-top-right-radius: 4px; }
  .bubble-time { font-size: 0.6rem; color: var(--text-muted); margin-top: 4px; display: block; }
  /* Typing */
  .typing { display: flex; gap: 4px; align-items: center; padding: 4px 2px; }
  .typing span { width: 6px; height: 6px; background: var(--text-muted); border-radius: 50%; animation: bounce 1.2s infinite; }
  .typing span:nth-child(2) { animation-delay: 0.2s; }
  .typing span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes bounce { 0%,60%,100%{transform:translateY(0)} 30%{transform:translateY(-5px)} }
  /* Input area */
  .input-area {
    display: flex;
    gap: 8px;
    padding: 1rem 1.2rem;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-top: 1px solid var(--border);
    border-radius: 0 0 16px 16px;
    align-items: center;
  }
  .input-area input {
    flex: 1;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 0.65rem 1rem;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    outline: none;
    transition: border-color 0.2s;
  }
  .input-area input:focus { border-color: var(--accent); }
  .input-area input::placeholder { color: var(--text-muted); }
  .send-btn {
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    border: none;
    border-radius: 10px;
    width: 42px; height: 42px;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    font-size: 1rem;
    transition: opacity 0.2s, transform 0.15s;
    flex-shrink: 0;
  }
  .send-btn:hover { opacity: 0.85; transform: scale(1.05); }
  @media(max-width:600px) {
    .debug-panel { display: none; }
    .wrapper { height: 100vh; }
    .header, .input-area { border-radius: 0; }
  }
</style>
</head>
<body>
<div class="wrapper">
  <div class="header">
    <div class="bot-avatar">⚙️</div>
    <div class="header-info">
      <h1>CampusBot <span style="color:var(--accent);font-size:0.75rem;">+ Preprocessing</span></h1>
      <p><span class="status-dot"></span>Text processing pipeline active</p>
    </div>
    <div class="week-tag">WEEK 2 · PREPROCESSING</div>
  </div>

  <div class="main">
    <div class="chat-area" id="chatArea"></div>
    <div class="debug-panel">
      <div class="debug-header">
        <div class="debug-dot"></div>
        NLP Pipeline
      </div>
      <div class="debug-content" id="debugContent">
        <div class="debug-empty">Enter a message to see the text preprocessing pipeline in action.</div>
      </div>
    </div>
  </div>

  <div class="input-area">
    <input type="text" id="userInput" placeholder="Ask anything — typos OK!" autocomplete="off"/>
    <button class="send-btn" onclick="sendMessage()">➤</button>
  </div>
</div>

<script>
// ─── STOPWORDS ───────────────────────────────────────────────
const STOPWORDS = new Set([
  "a","an","the","is","it","in","on","at","to","for","of","and","or","but",
  "be","was","are","were","this","that","these","those","i","me","my","we",
  "you","he","she","they","do","does","did","have","has","had","will","would",
  "can","could","should","may","might","shall","what","when","where","which",
  "who","how","why","about","with","from","by","its","their","our","your","just",
  "so","if","then","than","also","too","very","here","there","any","all","both"
]);

// ─── TYPO MAP ────────────────────────────────────────────────
const TYPO_MAP = {
  "feee": "fee", "feees": "fees", "fess": "fees", "fuee": "fee",
  "addmission": "admission", "admision": "admission", "admissions": "admission",
  "exm": "exam", "exmas": "exams", "exams": "exam",
  "hostle": "hostel", "hostell": "hostel",
  "scolarship": "scholarship", "scholarships": "scholarship", "scholarhip": "scholarship",
  "placment": "placement", "placements": "placement",
  "conatct": "contact", "contect": "contact", "contct": "contact",
  "timeing": "timing", "timmings": "timing", "timings": "timing",
  "libary": "library", "libray": "library",
  "hellp": "help", "helo": "hello"
};

// ─── FAQ DATA ────────────────────────────────────────────────
const faqs = [
  { keywords: ["fee","cost","payment","tuition"], answer: "📋 <b>Fee Structure:</b><br>• B.Tech: ₹2,10,000/year<br>• M.Tech: ₹1,80,000/year<br>• Hostel + Mess: ₹90,000/year<br>Fees paid in two semester installments." },
  { keywords: ["admission","apply","enroll","join"], answer: "📝 <b>Admission:</b><br>1. Online form at symbiosis.ac.in<br>2. SET/JEE entrance<br>3. Counselling & document check<br>4. Confirmation payment<br>Applications: March–April." },
  { keywords: ["timing","schedule","hour","open","time"], answer: "🕘 <b>Timings:</b><br>• Classes: 8 AM – 5 PM<br>• Library: 8 AM – 9 PM<br>• Admin: 9:30 AM – 5:30 PM" },
  { keywords: ["contact","phone","email","address","reach"], answer: "📞 <b>Contact:</b><br>Phone: +91-712-XXXXXXX<br>Email: info@sitng.edu.in<br>Helpdesk: support@sitng.edu.in" },
  { keywords: ["hostel","accommodation","room","stay","dorm"], answer: "🏠 <b>Hostel:</b><br>• Separate boys & girls blocks<br>• AC & Non-AC rooms<br>• 24/7 security & Wi-Fi<br>• Mess fee: ₹3,500/month" },
  { keywords: ["scholarship","merit","financial","aid","waiver"], answer: "🏆 <b>Scholarships:</b><br>• Merit (>90%): 25% fee waiver<br>• Sports quota: Up to 50%<br>• Govt SC/ST/OBC schemes" },
  { keywords: ["exam","test","assessment","paper","result"], answer: "📖 <b>Exams:</b><br>• Mid-Sem: Oct & Mar<br>• End-Sem: Nov & May<br>• Results in 3 weeks<br>• Revaluation: 7 days window" },
  { keywords: ["course","branch","program","department","stream"], answer: "🎓 <b>Programs:</b><br>B.Tech: CSE, IT, ECE, Mech, Civil<br>M.Tech: CSE, ECE, Structural<br>MBA, MCA available" },
  { keywords: ["placement","job","company","recruit","internship","career"], answer: "💼 <b>Placements 2024:</b><br>• Avg: ₹6.2 LPA | Highest: ₹32 LPA<br>• Top recruiters: TCS, Infosys, Wipro<br>• Placement rate: 85%+" },
  { keywords: ["library","book","resource","journal"], answer: "📚 <b>Library:</b><br>• 50,000+ books, 200+ journals<br>• Digital access via INFLIBNET<br>• Issue: 3 books / 14 days" },
  { keywords: ["hello","hi","hey","greet","help","start"], answer: "👋 <b>Hello!</b> I'm CampusBot with text preprocessing.<br>Ask about fees, admission, exams, hostel, or placements!" }
];

const defaultMsg = "🤔 Couldn't match your query. Try: <b>fees, admission, exams, hostel, placement, library, contact</b>";

// ─── TEXT PREPROCESSING PIPELINE ────────────────────────────
function pipeline(raw) {
  const steps = {};

  // Step 1: Lowercase
  steps.lowercase = raw.toLowerCase();

  // Step 2: Remove punctuation
  steps.noPunct = steps.lowercase.replace(/[^a-z0-9\s]/g, '');

  // Step 3: Tokenize
  steps.tokens = steps.noPunct.trim().split(/\s+/).filter(Boolean);

  // Step 4: Fix typos
  steps.corrected = steps.tokens.map(w => TYPO_MAP[w] || w);
  steps.typoFixes = steps.tokens
    .map((w, i) => ({ original: w, fixed: steps.corrected[i] }))
    .filter(x => x.original !== x.fixed);

  // Step 5: Remove stopwords
  steps.filtered = steps.corrected.filter(w => !STOPWORDS.has(w));
  steps.removedStopwords = steps.corrected.filter(w => STOPWORDS.has(w));

  // Final string
  steps.final = steps.filtered.join(' ');

  return steps;
}

function findAnswer(processedTokens) {
  for (const faq of faqs) {
    if (faq.keywords.some(k => processedTokens.includes(k))) {
      return faq.answer;
    }
  }
  return null;
}

// ─── DEBUG PANEL ─────────────────────────────────────────────
function updateDebug(steps, raw) {
  const panel = document.getElementById('debugContent');
  let html = '';

  const sec = (label, content) => `<div class="debug-section"><div class="debug-label">${label}</div>${content}</div>`;

  html += sec('① Raw Input', `<div class="debug-value">"${escHtml(raw)}"</div>`);
  html += sec('② Lowercase', `<div class="debug-value">"${escHtml(steps.lowercase)}"</div>`);
  html += sec('③ Remove Punctuation', `<div class="debug-value">"${escHtml(steps.noPunct)}"</div>`);

  const tokensHtml = steps.tokens.map(t => `<span class="debug-token">${escHtml(t)}</span>`).join('');
  html += sec(`④ Tokens (${steps.tokens.length})`, `<div style="line-height:2">${tokensHtml || '<span class="debug-empty">none</span>'}</div>`);

  if (steps.typoFixes.length > 0) {
    const fixHtml = steps.typoFixes.map(f =>
      `<span class="debug-removed">${escHtml(f.original)}</span>→<span class="debug-token">${escHtml(f.fixed)}</span>`
    ).join(' ');
    html += sec('⑤ Typo Fixes', `<div style="line-height:2">${fixHtml}</div>`);
  } else {
    html += sec('⑤ Typo Fixes', `<div class="debug-empty">No typos detected</div>`);
  }

  const swHtml = steps.removedStopwords.map(w => `<span class="debug-removed">${escHtml(w)}</span>`).join('');
  html += sec(`⑥ Remove Stopwords (−${steps.removedStopwords.length})`, `<div style="line-height:2">${swHtml || '<span class="debug-empty">none removed</span>'}</div>`);

  const finalHtml = steps.filtered.map(t => `<span class="debug-token" style="border-color:rgba(74,222,128,0.3);background:rgba(74,222,128,0.07);color:#4ade80">${escHtml(t)}</span>`).join('');
  html += sec(`✅ Final Tokens (${steps.filtered.length})`, `<div style="line-height:2">${finalHtml || '<span class="debug-empty">empty after processing</span>'}</div>`);

  panel.innerHTML = html;
}

function escHtml(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

// ─── MESSAGING ───────────────────────────────────────────────
function getTime() {
  return new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
}

function addMessage(content, type) {
  const area = document.getElementById('chatArea');
  const row = document.createElement('div');
  row.className = `msg-row ${type}`;
  const avatar = document.createElement('div');
  avatar.className = 'msg-avatar';
  avatar.textContent = type === 'bot' ? '⚙️' : '👤';
  const bubble = document.createElement('div');
  bubble.className = 'bubble';
  bubble.innerHTML = content;
  const time = document.createElement('span');
  time.className = 'bubble-time';
  time.textContent = getTime();
  bubble.appendChild(time);
  row.appendChild(avatar);
  row.appendChild(bubble);
  area.appendChild(row);
  area.scrollTop = area.scrollHeight;
}

function showTyping() {
  const area = document.getElementById('chatArea');
  const row = document.createElement('div');
  row.className = 'msg-row bot'; row.id = 'typing-indicator';
  const av = document.createElement('div'); av.className = 'msg-avatar'; av.textContent = '⚙️';
  const b = document.createElement('div'); b.className = 'bubble';
  b.innerHTML = '<div class="typing"><span></span><span></span><span></span></div>';
  row.appendChild(av); row.appendChild(b);
  area.appendChild(row); area.scrollTop = area.scrollHeight;
}

function removeTyping() {
  const el = document.getElementById('typing-indicator');
  if (el) el.remove();
}

function sendMessage() {
  const input = document.getElementById('userInput');
  const raw = input.value.trim();
  if (!raw) return;

  addMessage(escHtml(raw), 'user');
  input.value = '';

  // Run preprocessing
  const steps = pipeline(raw);
  updateDebug(steps, raw);
  console.log('[Week 2 Preprocessing Pipeline]', steps);

  showTyping();
  setTimeout(() => {
    removeTyping();
    const answer = findAnswer(steps.filtered);
    addMessage(answer || defaultMsg, 'bot');
  }, 600);
}

document.getElementById('userInput').addEventListener('keydown', e => {
  if (e.key === 'Enter') sendMessage();
});

window.onload = () => {
  setTimeout(() => {
    addMessage("⚙️ <b>Week 2: Text Preprocessing Active!</b><br><br>Watch the <b>NLP Pipeline panel</b> (right side) as you type — it shows:<br>• Lowercase → Tokenize → Typo fix → Remove stopwords<br><br>Try typing with typos like <b>'feees'</b> or <b>'addmission'</b>!", 'bot');
  }, 300);
};
</script>
</body>
</html>
